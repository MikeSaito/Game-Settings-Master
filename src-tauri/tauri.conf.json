{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Game Settings Master",
  "version": "1.0.2",
  "identifier": "com.mike.ue-settings-master",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Game Settings Master",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 750
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://cdn.cloudflare.steamstatic.com; connect-src 'self' https://github.com ipc:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "devCsp": "default-src 'self'; img-src 'self' asset: data: https://cdn.cloudflare.steamstatic.com; connect-src 'self' https://github.com ipc: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "catalog/": "catalog/",
      "games/": "games/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMDcwOUEwN0QzMzY0NTcKUldSWFpETjlvQWtIL3grVDFQeWhlOWFuakRPcWJUY2ZjVjA1cTlkSStWaVJhUDZVQkNPY2p4WDEK",
      "endpoints": [
        "https://github.com/MikeSaito/Game-Settings-Master/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
