{
  "id": "ultra-low",
  "name": "Ultra Low",
  "description": "Картошка: 45% разрешения, sg.* на нуле. Только меню — без Engine.ini, чтобы не конфликтовать с игрой.",
  "files": {
    "GameUserSettings.ini": {
      "[ScalabilityGroups]": {
        "sg.ResolutionQuality": "45",
        "sg.ViewDistanceQuality": "0",
        "sg.AntiAliasingQuality": "0",
        "sg.ShadowQuality": "0",
        "sg.GlobalIlluminationQuality": "0",
        "sg.ReflectionQuality": "0",
        "sg.PostProcessQuality": "0",
        "sg.TextureQuality": "0",
        "sg.EffectsQuality": "0",
        "sg.FoliageQuality": "0",
        "sg.ShadingQuality": "0",
        "sg.LandscapeQuality": "0",
        "sg.CloudsQuality": "0"
      },
      "[/Script/Engine.GameUserSettings]": {
        "bUseVSync": "False",
        "bUseDynamicResolution": "False",
        "FullscreenMode": "1",
        "ResolutionSizeX": "{{width}}",
        "ResolutionSizeY": "{{height}}",
        "FrameRateLimit": "0.000000"
      }
    }
  }
}
