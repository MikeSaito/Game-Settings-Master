<?xml version="1.0"?>
<Presets> 
    <!-- CLEAR WEATHER -->               
    <Preset name="Clear" severity="Clear" cloudScape="Clear" lighting="Clear" />
    <AllowedTransition preset1="Clear" chance="1.0" preset2="CloudyA"/>
	<AllowedTransition preset1="Clear" chance="1.0" preset2="CloudyB"/>
    
    <!-- CLOUDY WEATHER -->  
    <Preset name="CloudyA" severity="Cloudy" cloudScape="CloudyA" lighting="Clear" />
	<Preset name="CloudyB" severity="Cloudy" cloudScape="CloudyB" lighting="Clear" />
    <AllowedTransition preset1="CloudyA" chance="1.0" preset2="ThreateningStormACloudyA"/>
	<AllowedTransition preset1="CloudyB" chance="1.0" preset2="ThreateningStormACloudyB"/>
	<AllowedTransition preset1="CloudyA" chance="1.0" preset2="ThreateningStormCCloudyA"/>
	<AllowedTransition preset1="CloudyB" chance="1.0" preset2="ThreateningStormCCloudyB"/>
    <AllowedTransition preset1="CloudyA" chance="1.0" preset2="CloudyB"/>
	
    <!-- THREATENING WEATHER -->
    <Preset name="ThreateningStormACloudyA" severity="Threatening" cloudScape="StormACloudyA" lighting="Threatening" />
	<Preset name="ThreateningStormACloudyB" severity="Threatening" cloudScape="StormACloudyB" lighting="Threatening" />
	<Preset name="ThreateningStormCCloudyA" severity="Threatening" cloudScape="StormCCloudyA" lighting="Threatening" />
	<Preset name="ThreateningStormCCloudyB" severity="Threatening" cloudScape="StormCCloudyB" lighting="Threatening" />
    <AllowedTransition preset1="ThreateningStormACloudyA" chance="1.0" preset2="StormBCloudyA"/>
	<AllowedTransition preset1="ThreateningStormACloudyB" chance="1.0" preset2="StormBCloudyB"/>
	<AllowedTransition preset1="ThreateningStormCCloudyA" chance="1.0" preset2="StormBCloudyA"/>
	<AllowedTransition preset1="ThreateningStormCCloudyB" chance="1.0" preset2="StormBCloudyB"/>
      
    <!-- STORMY WEATHER -->
	<Preset name="StormBCloudyA" severity="Storm" cloudScape="StormBCloudyA" lighting="Storm3" />
	<Preset name="StormBCloudyB" severity="Storm" cloudScape="StormBCloudyB" lighting="Storm3" />
    
    <!-- RAIN DEFINITION -->
    <RainDefinition RainNormalFX = "WATER_Rain_Impact_Single"  RainTorrentialFX = "WATER_Rain_Impact_Single_Island" RainMistFX = "WATER_Rain_Mist" RainSplashesFX = "WATER_Rain_Splash" SnowFX = "WATER_Rain_Impact_Single" TorrentialRainThreshold = "0.62" />
</Presets>